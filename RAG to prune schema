y'][index]\n        text = prompt+ f\"\"\"<|start_header_id|>assistant<|end_header_id|>\n\n{query}<|eot_id|>\"\"\"\n        \n        return {'text':text}\n    return{'text': prompt}\n\ntext = build_prompt( schema_lookup, index =3629,dataset = train_df, inference = False, schema_type = 1, compact_schema = False )\nprint(len(text['text']))\nprint(text['text'])","metadata":{"trusted":true,"scrolled":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# SCHEMA COMPACTION","metadata":{}},{"cell_type":"code","source":"# import numpy as np\nfrom sentence_transformers import SentenceTransformer, util\nmodel = SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')\n\nfrom sklearn.metrics.pairwise import cosine_similarity\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"list_of_strings = [\n    '- era (number) | e.g: [10.5, 3.6, 0]',\n    '- sv (number) | e.g: [0, 0, 0]',\n    \"- name_last (text) | e.g: ['Aardsma', 'Aaron', 'Aaron']\",\n    \"- name_first (text) | e.g: ['David', 'Hank', 'Tommie']\",\n]\nquestion = 'fWhat are the first name and last name of the players who were paid salary by team Washington Nationals in both 2005 and 2007?'\n\ncol_embd = model.encode(list_of_strings)\nques_embd = model.encode(question)\n\nsim_scores = cosine_similarity(col_embd, ques_embd.reshape(1, -1))\nprint(sim_scores)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def parse_columns_from_augmented_schema(db_id):\n\n    \"\"\"\n    Returns list of dicts:\n    [\n      {\n        'table_name': 'matches',\n        'column_line': '- winner_name (text) | e.g: [...]',\n        'chunk': 'Table: matches | Column: winner_name (text) | e.g: [...]'\n      },\n      ...\n    ]\n    The 'chunk' is what gets embedded — it includes table context so the\n    embedding knows which table this column belongs to.\n    \"\"\"\n    schema = schema_lookup[db_id]['augmented_schema']\n\n    column_chunks = []\n\n    for table_info in schema.split('\\n\\n'):\n        \n        match = re.search(r\"Table:\\s*(\\w+)\", table_info)\n        if match:\n            table_name = match.group(1)\n        \n        parts = re.split(r\"## Columns:\\s*\", table_info)\n\n        if len(parts) > 1:\n            cols_info = parts[1]\n\n        for col_info in cols_info.split('\\n'):\n            match = re.search(r\"\\w+\", col_info)\n\n            if match:\n                col_name = match.group()\n                \n            dic = {}\n\n            dic['col_name'] = col_name\n            dic['db_id'] = db_id\n            dic['table_name'] = table_name\n            dic['col_info'] = col_info\n            dic['chunk'] = f'Table: {table_name} | Column_info: {col_info}'\n            dic['is_pk'] = True if re.search(r\"\\bPK\\b\", col_info) else False\n            dic['is_fk'] = True if re.search(r\"\\bFK\\b\", col_info) else False\n\n            column_chunks.append(dic)\n\n\n    return column_chunks\n                   \ndb_id = 'concert_singer'\ncolumn_chunks =  parse_columns_from_augmented_schema(db_id)\ncolumn_chunks[20]    \n    ","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def create_columns_embeddings(db_id):\n\n    column_chunks = parse_columns_from_augmented_schema(db_id)\n\n    n_cols = len(column_chunks)\n    embedding_dim = model.get_sentence_embedding_dimension()\n\n    list_of_strings = []\n\n    for i, col_chunk in enumerate(column_chunks):\n        list_of_strings.append(col_chunk['col_info'])\n\n    embeddings = model.encode(list_of_strings)\n\n    # db_id = column_chunks[0]['db_id']\n    schema_lookup[db_id]['embeddings'] = embeddings\n    schema_lookup[db_id]['column_chunks'] = column_chunks\n    \n    return embeddings, schema_lookup\n\nfor db_id, content in schema_lookup.items():\n    embeddings, schema_lookup = create_columns_embeddings(db_id )\n    \n\nembeddings, schema_lookup = create_columns_embeddings(db_id = 'baseball_1')\nprint(embeddings.shape)\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from sklearn.metrics.pairwise import cosine_similarity\n\ndef scoring_columns(db_id, question):\n\n    q_embd = model.encode(question)\n    col_embd = schema_lookup[db_id]['embeddings']\n    column_chunks = schema_lookup[db_id]['column_chunks']\n    \n    sim_scores = cosine_similarity(col_embd, q_embd.reshape(1, -1))\n    \n    scored_columns = list(zip(sim_scores, column_chunks))\n    scored_columns.sort(key=lambda x: x[0], reverse=True)\n    \n    return scored_columns\n    \nquestion = 'What are the first name and last name of the players who were paid salary by team Washington Nationals in both 2005 and 2007?'\nscored_columns = scoring_columns(db_id = 'baseball_1', question= question )\n\nprint(scored_columns[1])  \nprint(len(scored_columns))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# print(scored_columns[:100])","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from collections import defaultdict\n\ndef building_compact_schema(scored_columns):\n\n    table_dic = defaultdict(list) # dictionary for table and its mapping with the pruned column. necessary for building schema\n    for i, col_data in enumerate(scored_columns):\n        score, dic = col_data\n\n        table_dic[dic['table_name']].append(dic['col_info'])\n\n    table_dic = {k: \"\\n\".join(v) for k,v in table_dic.items()}\n\n    # BUILDING SCHEMA\n    schema_lines =[]\n    for table_name, cols in table_dic.items():\n        schema_lines.append(f'# Table: {table_name} \\n{cols}')\n    s = '\\n\\n'.join(schema_lines)\n        \n    return s    \n        \n\n    # return table_dic\n\nresult = building_compact_schema(scored_columns)\nprint(result)\n        ","metadata":{"trusted":true,"scrolled":true},"outputs":[],"execution_count":null},{"cel