nput_ids'])\n        \n    return prompt\n\nprompt = adaptive_pruning(index = 3698, dataset = train_df ,token_limit = 2048)\nprint(prompt)","metadata":{"trusted":true,"scrolled":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"filtered_df = filtered_df.drop(columns=['query_toks','query_toks_no_value','question_toks','count_tables' ])\nfiltered_df.head(3)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"prompts = []\nlengths = []\nfor i in filtered_df['original_index']:\n    \n    new_prompt = adaptive_pruning(index = i, dataset = train_df ,token_limit = 2048)\n    # new_prompt = build_prompt(schema_lookup, index=i, dataset=train_df, \n    #                  inference=False, schema_type= 1, compact_schema = compact_schema)['text']\n    length = len(tokenizer(new_prompt)['input_ids'])\n    prompts.append(new_prompt)\n    lengths.append(length)\n\nfiltered_df['compact_prompt'] = prompts\nfiltered_df['New_T'] = lengths\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"filtered_df = filtered_df.sort_values('New_T', ascending = False).reset_index(drop=True)\nprint(filtered_df.head(3))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"filtered_df.to_csv('filtered_compact_prompt.csv', index=False)","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}