# %% [code] {"id":"ZVwot3pmZ4dE","outputId":"b405bb50-d0cd-4fc3-b4b0-e36e1d9e2879","jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-04-15T11:16:36.351472Z","iopub.execute_input":"2026-04-15T11:16:36.352073Z","iopub.status.idle":"2026-04-15T11:16:36.370338Z","shell.execute_reply.started":"2026-04-15T11:16:36.352031Z","shell.execute_reply":"2026-04-15T11:16:36.369482Z"}}
def parse_foreign_keys(fk_string):
    fk_map = {}
    words = fk_string
    fk_string = words.split()
    for i,word in enumerate(fk_string):
        if word =='equals':
            first_table = fk_string[i-3]
            second_table = fk_string[i+1]

            fk_map[(first_table, fk_string[i-1])] = (second_table, fk_string[i+3])


    return fk_map
map = parse_foreign_keys(fk_string = schema_lookup[db]['Foreign Keys'])
