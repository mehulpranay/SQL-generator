# %% [code] {"id":"29ALg1GK0qk4","jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-04-15T11:16:36.446331Z","iopub.execute_input":"2026-04-15T11:16:36.446656Z","iopub.status.idle":"2026-04-15T11:16:37.224556Z","shell.execute_reply.started":"2026-04-15T11:16:36.446632Z","shell.execute_reply":"2026-04-15T11:16:37.223595Z"}}
def build_prompt( schema_lookup, index, dataset, inference = False ):

    df = dataset
    prompt = ''

    db_id = df['db_id'][index]
    question = df['question'][index]
    schema = schema_lookup[db_id]['format_schema']
    prompt = f"""Instruct: Convert the natural language question to SQL using the schema below. Use SQLite syntax and SQLite functions only.

### Schema:
{schema}

### Question:
{question}

Output: """

    if inference == False:
        query = df['query'][index]
        full_text = prompt+ query

    return full_text, prompt

train_df = pd.DataFrame(dataset['train'])
validation_df = pd.DataFrame(dataset['validation'])

full_text,prompt = build_prompt( schema_lookup, index =0,dataset = validation_df, inference = False )

