# %% [code] {"id":"NHdOO4ucBSCO","outputId":"5cdd1d65-6ac3-474e-c999-838e18e9ac44","jupyter":{"outputs_hidden":false},"scrolled":true,"execution":{"iopub.status.busy":"2026-04-15T11:17:43.367375Z","iopub.execute_input":"2026-04-15T11:17:43.367772Z","iopub.status.idle":"2026-04-15T11:17:43.381943Z","shell.execute_reply.started":"2026-04-15T11:17:43.367716Z","shell.execute_reply":"2026-04-15T11:17:43.381325Z"}}
def tokenize(index, dataset, inference=False):
    full_text, prompt = build_prompt(schema_lookup, index, dataset, inference)
    full_text+= tokenizer.eos_token
    
    tokens = tokenizer(
        full_text ,
        truncation= False,   
        padding= False,      # no padding yet. Datacollator automatically does dynamic padding.
        return_tensors= None
    )


    prompt_tokens = tokenizer(
        prompt, 
        truncation = False, 
        padding = False, 
        return_tensors = None
    )

    f_ids = tokens['input_ids']
    p_ids = prompt_tokens['input_ids']

    # print(len(f_ids))
    # print(len(p_ids))

    boundary_idx = len(p_ids)

    for i in range(len(f_ids)):
        if f_ids[i]!= p_ids[i]:
            boundary_idx = i
            break

    
    tokens['labels'] = [-100]* (boundary_idx) + tokens['input_ids'][boundary_idx:] 

    
    return tokens

